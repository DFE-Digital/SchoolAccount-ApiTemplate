#!/usr/bin/env bash
# Checks that staged C# files are formatted with CSharpier.
set -euo pipefail

staged_files=()
while IFS= read -r file; do
  staged_files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR -- '*.cs')

if [[ ${#staged_files[@]} -eq 0 ]]; then
  exit 0
fi

if ! dotnet tool run csharpier --version >/dev/null 2>&1; then
  dotnet tool restore >/dev/null
fi

if ! dotnet csharpier check "${staged_files[@]}"; then
  echo
  echo "Commit blocked: the files above are not formatted."
  echo "Run 'dotnet csharpier format .' and stage the changes."
  exit 1
fi
